<Page x:Class="BarInventoryApp.Pages.CocktailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Картотека коктейлей"
      Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="← Назад" Click="OnBackClick" 
                        Style="{StaticResource SecondaryButton}" 
                        Padding="12,8" Margin="0,0,10,0"/>
            </StackPanel>
            <TextBlock Text="🍹 Картотека коктейлей" 
                       Style="{StaticResource PageTitle}" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center"
                       Margin="0"/>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource Card}" Padding="0">
                <DataGrid ItemsSource="{Binding Cocktails}" SelectedItem="{Binding SelectedCocktail}"
                          AutoGenerateColumns="False" IsReadOnly="True" Style="{StaticResource ModernDataGrid}"
                          PreviewMouseLeftButtonDown="OnCocktailLeftClick">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="✏️ Изменить" Command="{Binding EditCommand}"/>
                            <MenuItem Header="🗑 Удалить" Command="{Binding DeleteCommand}" Foreground="Red"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                        <DataGridTextColumn Header="НАЗВАНИЕ" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="КОЛ-ВО ИНГРЕДИЕНТОВ" Binding="{Binding CocktailIngredients.Count}" Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <StackPanel Grid.Column="1" Margin="16,0,0,0">
                <Button Content="➕ Добавить" Command="{Binding AddCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,0,12"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
