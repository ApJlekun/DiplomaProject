<Window x:Class="BarInventoryApp.Pages.CategoryIngredientsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding CategoryName}" Height="450" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        Style="{StaticResource ModernWindow}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding CategoryName}" Style="{StaticResource PageTitle}" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
            <ComboBox Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}" 
                      ItemsSource="{Binding Ingredients}"
                      DisplayMemberPath="Name"
                      IsEditable="True"
                      IsTextSearchEnabled="False"
                      StaysOpenOnEdit="True"
                      Width="300"
                      Height="35"
                      FontSize="14"
                      VerticalContentAlignment="Center"/>
            <TextBlock Text="🔍 Поиск ингредиента" VerticalAlignment="Center" Margin="10,0,0,0" 
                       FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"/>
        </StackPanel>

        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0" Margin="0,0,0,15">
            <DataGrid ItemsSource="{Binding Ingredients}" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True"
                      Style="{StaticResource ModernDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="НАИМЕНОВАНИЕ" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="КОЛИЧЕСТВО" Binding="{Binding Quantity, StringFormat=N2}" Width="120"/>
                    <DataGridTextColumn Header="ЕД. ИЗМ." Binding="{Binding Unit}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Button Grid.Row="3" Content="Закрыть" Click="OnCloseClick"
                Style="{StaticResource SecondaryButton}" 
                Width="120" HorizontalAlignment="Right"/>
    </Grid>
</Window>
