<Window x:Class="BarInventoryApp.Pages.ReceiptHistoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="История чеков" Height="450" Width="600"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        Style="{StaticResource ModernWindow}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="📜 История чеков" Style="{StaticResource PageTitle}" Margin="0,0,0,20"/>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0" Margin="0,0,0,15">
            <DataGrid ItemsSource="{Binding Receipts}" 
                      SelectedItem="{Binding SelectedReceipt}"
                      AutoGenerateColumns="False" 
                      IsReadOnly="True"
                      Style="{StaticResource ModernDataGrid}"
                      MouseDoubleClick="OnMouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="НОМЕР ЧЕКА" Binding="{Binding Id}" Width="100"/>
                    <DataGridTextColumn Header="СФОРМИРОВАЛ" Binding="{Binding User.Login}" Width="*"/>
                    <DataGridTextColumn Header="КОГДА" Binding="{Binding CreatedAt, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="150"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Button Grid.Row="2" Content="Закрыть" Command="{Binding CloseCommand}"
                Style="{StaticResource SecondaryButton}" 
                Width="120" HorizontalAlignment="Right"/>
    </Grid>
</Window>
