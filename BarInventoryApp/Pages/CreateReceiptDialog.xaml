<Window x:Class="BarInventoryApp.Pages.CreateReceiptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сформировать чек" Height="500" Width="600"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        Style="{StaticResource ModernWindow}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="🧾 Списание ингредиентов" Style="{StaticResource PageTitle}" Margin="0,0,0,20"/>

        <!-- Панель добавления -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Margin="0,0,10,0">
                    <TextBlock Text="Ингредиент" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource ModernTextBox}"/>
                    <ListBox ItemsSource="{Binding FoundIngredients}" 
                             SelectedItem="{Binding SelectedIngredient}"
                             MaxHeight="100" Margin="0,5,0,0"
                             Visibility="{Binding FoundIngredients.Count, Converter={StaticResource NullToVisibilityConverter}}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>

                <StackPanel Grid.Column="1" Width="100" Margin="0,0,10,0">
                    <TextBlock Text="Количество" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource ModernTextBox}"/>
                </StackPanel>

                <Button Grid.Column="2" Content="Добавить" 
                        Command="{Binding AddItemCommand}"
                        Style="{StaticResource PrimaryButton}"
                        VerticalAlignment="Bottom" Height="40"/>
            </Grid>
        </Border>

        <!-- Список элементов -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0" Margin="0,0,0,15">
            <DataGrid ItemsSource="{Binding ReceiptItems}" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True"
                      Style="{StaticResource ModernDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ИНГРЕДИЕНТ" Binding="{Binding IngredientName}" Width="*"/>
                    <DataGridTextColumn Header="КОЛИЧЕСТВО" Binding="{Binding Quantity}" Width="120"/>
                    <DataGridTextColumn Header="ЕД. ИЗМ." Binding="{Binding Unit}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Кнопки управления -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Отменить" Command="{Binding CancelCommand}"
                    Style="{StaticResource SecondaryButton}" 
                    Width="120" Margin="0,0,10,0"/>
            <Button Content="Провести чек" Command="{Binding ProcessCommand}"
                    Style="{StaticResource PrimaryButton}" 
                    Width="150"/>
        </StackPanel>
    </Grid>
</Window>
