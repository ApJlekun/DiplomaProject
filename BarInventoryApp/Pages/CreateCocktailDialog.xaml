<Window x:Class="BarInventoryApp.Pages.CreateCocktailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Коктейль" Height="750" Width="700"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        Style="{StaticResource ModernWindow}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="🍹 Рецепт коктейля" Style="{StaticResource PageTitle}" Margin="0,0,0,20"/>

        <!-- Название -->
        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <TextBlock Text="Название коктейля" Style="{StaticResource FieldLabel}"/>
            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}"/>
        </StackPanel>

        <!-- Добавление ингредиента -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Margin="0,0,15,0">
                    <TextBlock Text="Ингредиент" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}"/>
                    <ListBox ItemsSource="{Binding FoundIngredients}" SelectedItem="{Binding SelectedIngredient}" 
                             MaxHeight="120" Margin="0,5,0,0"
                             Visibility="{Binding FoundIngredients.Count, Converter={StaticResource NullToVisibilityConverter}}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>

                <StackPanel Grid.Column="1" Width="100" Margin="0,0,15,0">
                    <TextBlock Text="Кол-во" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}"/>
                </StackPanel>

                <Button Grid.Column="2" Content="Добавить в состав" Command="{Binding AddIngredientCommand}" 
                        Style="{StaticResource PrimaryButton}" VerticalAlignment="Bottom" Height="42" Padding="15,0"/>
            </Grid>
        </Border>

        <!-- Список состава -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="0" Margin="0,0,0,15">
            <DataGrid ItemsSource="{Binding CocktailIngredients}" AutoGenerateColumns="False" IsReadOnly="True" Style="{StaticResource ModernDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ИНГРЕДИЕНТ" Binding="{Binding IngredientName}" Width="*"/>
                    <DataGridTextColumn Header="КОЛИЧЕСТВО" Binding="{Binding Quantity}" Width="100"/>
                    <DataGridTextColumn Header="ЕД. ИЗМ." Binding="{Binding Unit}" Width="100"/>
                    <DataGridTemplateColumn Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="🗑" Command="{Binding DataContext.RemoveIngredientCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                        CommandParameter="{Binding}" Style="{StaticResource IconButton}" Foreground="Red"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Кнопки -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Отмена" Command="{Binding CancelCommand}" Style="{StaticResource SecondaryButton}" Width="100" Margin="0,0,10,0"/>
            <Button Content="Сохранить" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButton}" Width="120"/>
        </StackPanel>
    </Grid>
</Window>
