<Page x:Class="BarInventoryApp.Pages.IngredientsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      Title="Ингредиенты"
      Background="{DynamicResource BackgroundBrush}" Foreground="{DynamicResource TextBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Grid Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button x:Name="BackButton" Content="← Назад" Click="OnBackClick" 
                        Style="{StaticResource SecondaryButton}" 
                        Padding="12,8" Margin="0,0,10,0"/>
                <Button Content="Выход" Click="OnLogoutClick" 
                        Style="{StaticResource SecondaryButton}" 
                        Padding="12,8"/>
            </StackPanel>
            <TextBlock Text="📦 Категории ингредиентов" 
                       Style="{StaticResource PageTitle}" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center"
                       Margin="0"/>
        </Grid>

        <!-- Панель действий -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="16" Margin="0,0,0,16">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <ComboBox x:Name="SearchComboBox"
                              Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}" 
                              ItemsSource="{Binding FilteredIngredients}"
                              SelectedItem="{Binding SelectedSearchIngredient, Mode=TwoWay}"
                              IsDropDownOpen="{Binding IsSearchDropDownOpen}"
                              DisplayMemberPath="Name"
                              IsEditable="True"
                              StaysOpenOnEdit="True"
                              IsTextSearchEnabled="False"
                              TextBoxBase.TextChanged="OnSearchTextChanged"
                              Width="300"
                              Height="40"
                              Padding="10,5"
                              FontSize="14"
                              Style="{StaticResource ModernComboBox}"
                              VerticalContentAlignment="Center">
                        <ComboBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel />
                            </ItemsPanelTemplate>
                        </ComboBox.ItemsPanel>
                    </ComboBox>
                    <TextBlock Text="🔍 Поиск ингредиентов" VerticalAlignment="Center" Margin="10,0,0,0" 
                               FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <Button Content="🧾 Чек" Command="{Binding CreateReceiptCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,8,0" Padding="16,10"
                            Visibility="{Binding CreateReceiptCommand, Converter={StaticResource NullToVisibilityConverter}}"/>
                    <Button Content="📜 История чеков" Command="{Binding ReceiptHistoryCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,8,0" Padding="16,10"
                            Visibility="{Binding ReceiptHistoryCommand, Converter={StaticResource NullToVisibilityConverter}}"/>
                    <Button Content="+ Новый ингредиент" Command="{Binding AddCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,8,0" Padding="16,10"
                            Visibility="{Binding AddCommand, Converter={StaticResource NullToVisibilityConverter}}"/>
                    <Button Content="📥 Импорт" Command="{Binding ImportCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,8,0" Padding="16,10"
                            Visibility="{Binding ImportCommand, Converter={StaticResource NullToVisibilityConverter}}"/>
                    <Button Content="🔍 Ревизия" Command="{Binding RevisionCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,8,0" Padding="16,10"
                            Visibility="{Binding RevisionCommand, Converter={StaticResource NullToVisibilityConverter}}"/>
                    <Button Content="📜 История ревизий" Command="{Binding RevisionHistoryCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,8,0" Padding="16,10"
                            Visibility="{Binding RevisionHistoryCommand, Converter={StaticResource NullToVisibilityConverter}}"/>
                    <Button Command="{Binding LowStockCommand}"
                            Style="{StaticResource DangerOutlineButton}"
                            Margin="0,0,8,0" Padding="16,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠️ Низкий остаток" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding LowStockCount}" FontSize="14" FontWeight="Bold"
                                       Foreground="{DynamicResource DangerBrush}" VerticalAlignment="Center"
                                       Margin="6,0,0,0"
                                       Visibility="{Binding LowStockCount, Converter={StaticResource PositiveIntToVisibilityConverter}}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Таблица категорий -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <DataGrid x:Name="CategoriesGrid"
                      ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding SelectedCategory}"
                      Style="{StaticResource ModernDataGrid}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      BorderThickness="0"
                      RowHeight="NaN"
                      MinRowHeight="44"
                      RowDetailsVisibilityMode="VisibleWhenSelected"
                      PreviewMouseLeftButtonDown="OnDataGridPreviewMouseDown">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="КАТЕГОРИЯ" Binding="{Binding Name}" Width="*" FontWeight="Bold"/>
                </DataGrid.Columns>
                <DataGrid.RowDetailsTemplate>
                    <DataTemplate>
                        <Border Background="Transparent" 
                                Padding="40,10,20,20" 
                                BorderBrush="{DynamicResource BorderBrush}" 
                                BorderThickness="0,1,0,0"
                                MaxWidth="{Binding Path=ActualWidth, RelativeSource={RelativeSource AncestorType=DataGrid}}">
                            <DataGrid ItemsSource="{Binding Ingredients}"
                                      SelectedItem="{Binding DataContext.SelectedIngredient, RelativeSource={RelativeSource AncestorType=Page}}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="None"
                                      SelectionMode="Single"
                                      MaxHeight="300"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      RowHeight="35"
                                      PreviewMouseLeftButtonUp="OnIngredientLeftClick"
                                      PreviewMouseRightButtonUp="OnIngredientRightClick">
                                <DataGrid.ContextMenu>
                                    <ContextMenu x:Name="IngredientMenu">
                                        <MenuItem Header="Изменить" 
                                                  Command="{Binding EditCommand}"
                                                  CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu}, Path=PlacementTarget.SelectedItem}"
                                                  Visibility="{Binding EditCommand, Converter={StaticResource NullToVisibilityConverter}}"/>
                                        <MenuItem Header="Удалить" 
                                                  Command="{Binding DeleteCommand}"
                                                  CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu}, Path=PlacementTarget.SelectedItem}"
                                                  Visibility="{Binding DeleteCommand, Converter={StaticResource NullToVisibilityConverter}}"/>
                                    </ContextMenu>
                                </DataGrid.ContextMenu>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="*" MinWidth="200"/>
                                    <DataGridTextColumn Header="Количество" Binding="{Binding Quantity, StringFormat=N3}" Width="100"/>
                                    <DataGridTextColumn Header="Ед.изм." Binding="{Binding Unit}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </DataTemplate>
                </DataGrid.RowDetailsTemplate>
            </DataGrid>
        </Border>
    </Grid>
</Page>
