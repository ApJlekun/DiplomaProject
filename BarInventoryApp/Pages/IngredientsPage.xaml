<Page x:Class="BarInventoryApp.Pages.IngredientsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      Title="Ингредиенты"
      Background="{DynamicResource BackgroundBrush}" Foreground="{DynamicResource TextBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Grid Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="← Назад" Click="OnBackClick" 
                        Style="{StaticResource SecondaryButton}" 
                        Padding="12,8" Margin="0,0,10,0"/>
                <Button Content="Выход" Click="OnLogoutClick" 
                        Style="{StaticResource SecondaryButton}" 
                        Padding="12,8"/>
            </StackPanel>
            <TextBlock Text="📦 Категории ингредиентов" 
                       Style="{StaticResource PageTitle}" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center"
                       Margin="0"/>
        </Grid>

        <!-- Панель действий -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="16" Margin="0,0,0,16">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <ComboBox Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}" 
                              ItemsSource="{Binding Categories}"
                              DisplayMemberPath="Name"
                              IsEditable="True"
                              StaysOpenOnEdit="True"
                              IsTextSearchEnabled="False"
                              Width="300"
                              Height="35"
                              FontSize="14"
                              Style="{StaticResource ModernComboBox}"
                              VerticalContentAlignment="Center"/>
                    <TextBlock Text="🔍 Поиск категорий" VerticalAlignment="Center" Margin="10,0,0,0" 
                               FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal">
                    <Button Content="🧾 Чек" Command="{Binding CreateReceiptCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,8,0" Padding="16,10"
                            Visibility="{Binding CreateReceiptCommand, Converter={StaticResource NullToVisibilityConverter}}"/>
                    <Button Content="📜 История чеков" Command="{Binding ReceiptHistoryCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,8,0" Padding="16,10"
                            Visibility="{Binding ReceiptHistoryCommand, Converter={StaticResource NullToVisibilityConverter}}"/>
                    <Button Content="+ Новый ингредиент" Command="{Binding AddCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,8,0" Padding="16,10"
                            Visibility="{Binding AddCommand, Converter={StaticResource NullToVisibilityConverter}}"/>
                    <Button Content="📥 Импорт" Command="{Binding ImportCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,8,0" Padding="16,10"
                            Visibility="{Binding ImportCommand, Converter={StaticResource NullToVisibilityConverter}}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Таблица категорий -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <DataGrid ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding SelectedCategory}"
                      Style="{StaticResource ModernDataGrid}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      BorderThickness="0"
                      MouseDoubleClick="OnMouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="КАТЕГОРИЯ" Binding="{Binding Name}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>
