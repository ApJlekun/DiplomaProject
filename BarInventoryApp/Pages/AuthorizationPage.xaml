<Page x:Class="BarInventoryApp.Pages.AuthorizationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BarInventoryApp.Pages"
      mc:Ignorable="d" 
      Title="Авторизация"
      Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Border Style="{StaticResource Card}" 
                HorizontalAlignment="Center" VerticalAlignment="Center" 
                Width="380">
            <StackPanel>
                <TextBlock Text="🍸" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,8"
                           Foreground="{DynamicResource TextBrush}"/>
                <TextBlock Text="Bar Inventory" 
                           Style="{StaticResource PageTitle}" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,8"/>
                <TextBlock Text="Войдите в систему для продолжения" 
                           Style="{StaticResource SubTitle}" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,24"/>
                
                <TextBlock Text="Логин" FontSize="13" FontWeight="Medium" 
                           Foreground="{DynamicResource TextBrush}" Margin="0,0,0,6"/>
                <TextBox x:Name="LoginBox" 
                         Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource ModernTextBox}"
                         Margin="0,0,0,16"/>
                
                <TextBlock Text="Пароль" FontSize="13" FontWeight="Medium" 
                           Foreground="{DynamicResource TextBrush}" Margin="0,0,0,6"/>
                <PasswordBox x:Name="PasswordBox"
                             PasswordChanged="PasswordBox_PasswordChanged"
                             Style="{StaticResource ModernPasswordBox}"
                             Margin="0,0,0,24"/>

                <Button Content="Войти" 
                        Command="{Binding LoginCommand}" 
                        Style="{StaticResource PrimaryButton}"
                        IsDefault="True"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,12"/>

                <Button Content="Выход" 
                        Click="OnExitClick" 
                        Style="{StaticResource SecondaryButton}"
                        HorizontalAlignment="Stretch"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
