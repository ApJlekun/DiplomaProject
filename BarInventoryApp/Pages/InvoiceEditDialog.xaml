<Window x:Class="BarInventoryApp.Pages.InvoiceEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование накладной" Height="600" Width="700"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        Style="{StaticResource ModernWindow}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" Margin="0,0,0,20">
            <TextBlock Text="📑 Накладная" Style="{StaticResource PageTitle}" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding StatusText}" Style="{StaticResource SubTitle}" 
                       VerticalAlignment="Center" Margin="20,0,0,0" FontWeight="Bold"/>
        </StackPanel>

        <!-- Панель добавления -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="15" Margin="0,0,0,15"
                Visibility="{Binding IsEditable, Converter={StaticResource NullToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Margin="0,0,10,0">
                    <TextBlock Text="Ингредиент" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource ModernTextBox}"/>
                    <ListBox ItemsSource="{Binding FoundIngredients}" 
                             SelectedItem="{Binding SelectedIngredient}"
                             MaxHeight="100" Margin="0,5,0,0"
                             Visibility="{Binding FoundIngredients.Count, Converter={StaticResource NullToVisibilityConverter}}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>

                <StackPanel Grid.Column="1" Width="100" Margin="0,0,10,0">
                    <TextBlock Text="Количество" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource ModernTextBox}"/>
                </StackPanel>

                <Button Grid.Column="2" Content="Добавить" 
                        Command="{Binding AddItemCommand}"
                        Style="{StaticResource PrimaryButton}"
                        VerticalAlignment="Bottom" Height="40"/>
            </Grid>
        </Border>

        <!-- Список элементов -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0" Margin="0,0,0,15">
            <DataGrid ItemsSource="{Binding InvoiceItems}" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True"
                      Style="{StaticResource ModernDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ИНГРЕДИЕНТ" Binding="{Binding IngredientName}" Width="*"/>
                    <DataGridTextColumn Header="КОЛИЧЕСТВО" Binding="{Binding Quantity}" Width="120"/>
                    <DataGridTextColumn Header="ЕД. ИЗМ." Binding="{Binding Unit}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Кнопки управления -->
        <Grid Grid.Row="3">
            <Button Content="📥 Экспорт в Excel" Command="{Binding ExportCommand}"
                    Style="{StaticResource SecondaryButton}" 
                    HorizontalAlignment="Left" Width="160"/>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Закрыть" Click="OnCloseClick"
                        Style="{StaticResource SecondaryButton}" 
                        Width="120" Margin="0,0,10,0"/>
                
                <StackPanel Orientation="Horizontal" Visibility="{Binding IsEditable, Converter={StaticResource NullToVisibilityConverter}}">
                    <Button Content="Сохранить" Command="{Binding SaveCommand}"
                            Style="{StaticResource PrimaryButton}" 
                            Width="120" Margin="0,0,10,0"/>
                    <Button Content="Провести" Command="{Binding PostCommand}"
                            Width="120">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
