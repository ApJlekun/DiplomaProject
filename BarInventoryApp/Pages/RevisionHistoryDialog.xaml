<Window x:Class="BarInventoryApp.Pages.RevisionHistoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="История ревизий" Height="500" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="📜 История ревизий" 
                   Style="{StaticResource PageTitle}" 
                   FontSize="22"
                   Margin="0,0,0,20"/>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
            <DataGrid ItemsSource="{Binding Revisions}"
                      SelectedItem="{Binding SelectedRevision}"
                      Style="{StaticResource ModernDataGrid}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      BorderThickness="0"
                      MouseDoubleClick="OnMouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="№" Binding="{Binding Id}" Width="60"/>
                    <DataGridTextColumn Header="СОЗДАНА" Binding="{Binding CreatedAt, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="150"/>
                    <DataGridTextColumn Header="ПРОВЕДЕНА" Binding="{Binding ProcessedAt, StringFormat={}{0:dd.MM.yyyy HH:mm}, TargetNullValue='Не проведена'}" Width="150"/>
                    <DataGridTextColumn Header="КТО СОЗДАЛ" Binding="{Binding User.Login}" Width="*"/>
                    <DataGridTextColumn Header="СТАТУС" Binding="{Binding Status}" Width="150">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Status}" Value="Проведена">
                                        <Setter Property="Foreground" Value="Green"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="Сохранена">
                                        <Setter Property="Foreground" Value="Orange"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
            <Button Content="Закрыть" Click="Close_Click" 
                    Style="{StaticResource SecondaryButton}"
                    Padding="24,12" Margin="0,0,12,0"/>
            <Button Content="Открыть" Command="{Binding OpenCommand}"
                    Style="{StaticResource PrimaryButton}"
                    Padding="24,12"/>
        </StackPanel>
    </Grid>
</Window>
