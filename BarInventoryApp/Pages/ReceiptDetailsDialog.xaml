<Window x:Class="BarInventoryApp.Pages.ReceiptDetailsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Детали чека" Height="350" Width="450"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        Style="{StaticResource ModernWindow}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="📋 Список списанного" Style="{StaticResource PageTitle}" Margin="0,0,0,20"/>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0" Margin="0,0,0,15">
            <DataGrid ItemsSource="{Binding Items}" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True"
                      Style="{StaticResource ModernDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ИНГРЕДИЕНТ" Binding="{Binding Ingredient.Name}" Width="*"/>
                    <DataGridTextColumn Header="КОЛИЧЕСТВО" Binding="{Binding Quantity}" Width="120"/>
                    <DataGridTextColumn Header="ЕД. ИЗМ." Binding="{Binding Ingredient.Unit}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Button Grid.Row="2" Content="Закрыть" Click="OnCloseClick"
                Style="{StaticResource SecondaryButton}" 
                Width="120" HorizontalAlignment="Right"/>
    </Grid>
</Window>
